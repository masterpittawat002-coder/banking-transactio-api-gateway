{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": "./src",
        "sourceMap": false,
        "declaration": false,
        "removeComments": false,
        "ignoreDeprecations": "6.0",
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "tests",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}
