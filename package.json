{
  "name": "banking-transactio-api-gateway",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:local": "cross-env NODE_ENV=local_development ts-node-dev --respawn -r tsconfig-paths/register src/app.ts",
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn -r tsconfig-paths/register src/app.ts",
    "staging": "cross-env NODE_ENV=staging ts-node-dev --respawn -r tsconfig-paths/register src/app.ts",
    "production": "cross-env NODE_ENV=production ts-node-dev --respawn -r tsconfig-paths/register src/app.ts",
    "docker:up": "docker-compose --env-file .env.local up -d",
    "docker:down": "docker-compose --env-file .env.local down",
    "docker:restart": "docker-compose --env-file .env.local restart",
    "docker:logs": "docker-compose --env-file .env.local logs -f",
    "docker:exec": "docker-compose --env-file .env.local exec app bash",
    "docker:ps": "docker-compose --env-file .env.local ps",
    "docker:build": "docker-compose --env-file .env.local build",
    "docker:pull": "docker-compose --env-file .env.local pull",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=tests/unit",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPatterns=tests/integration --runInBand",
    "test:coverage": "jest --coverage",
    "build": "tsc -p tsconfig.build.json",
    "start": "node -r ./register-paths.js dist/app.js",
    "build:dev": "cross-env NODE_ENV=development npm run build",
    "build:staging": "cross-env NODE_ENV=staging npm run build",
    "build:prod": "cross-env NODE_ENV=production npm run build",
    "docker:build:dev": "docker-compose --env-file .env.development build app",
    "docker:build:staging": "docker-compose --env-file .env.staging build app",
    "docker:build:prod": "docker-compose --env-file .env.production build app",
    "docker:up:dev": "docker-compose --env-file .env.development up -d",
    "docker:up:staging": "docker-compose --env-file .env.staging up -d",
    "docker:up:prod": "docker-compose --env-file .env.production up -d",
    "docker:down:dev": "docker-compose --env-file .env.development down",
    "docker:down:staging": "docker-compose --env-file .env.staging down",
    "docker:down:prod": "docker-compose --env-file .env.production down",
    "docker:restart:dev": "docker-compose --env-file .env.development restart",
    "docker:restart:staging": "docker-compose --env-file .env.staging restart",
    "docker:restart:prod": "docker-compose --env-file .env.production restart",
    "docker:logs:dev": "docker-compose --env-file .env.development logs -f",
    "docker:logs:staging": "docker-compose --env-file .env.staging logs -f",
    "docker:logs:prod": "docker-compose --env-file .env.production logs -f",
    "docker:exec:dev": "docker-compose --env-file .env.development exec app bash",
    "docker:exec:staging": "docker-compose --env-file .env.staging exec app bash",
    "docker:exec:prod": "docker-compose --env-file .env.production exec app bash",
    "docker:ps:dev": "docker-compose --env-file .env.development ps",
    "docker:ps:staging": "docker-compose --env-file .env.staging ps",
    "docker:ps:prod": "docker-compose --env-file .env.production ps",
    "docker:pull:dev": "docker-compose --env-file .env.development pull",
    "docker:pull:staging": "docker-compose --env-file .env.staging pull",
    "docker:pull:prod": "docker-compose --env-file .env.production pull"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masterpittawat002-coder/banking-transactio-api-gateway.git"
